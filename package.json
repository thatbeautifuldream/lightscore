{
  "name": "lightscore",
  "type": "module",
  "version": "0.1.2",
  "description": "Lighthouse scores in your terminal, with concrete fixes for everything below 100 — and a markdown report your coding agent can act on.",
  "author": "Milind Mishra <milind.mishra4@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thatbeautifuldream/lightscore.git"
  },
  "homepage": "https://github.com/thatbeautifuldream/lightscore#readme",
  "bugs": "https://github.com/thatbeautifuldream/lightscore/issues",
  "keywords": [
    "lighthouse",
    "performance",
    "audit",
    "cli",
    "accessibility",
    "seo",
    "web-vitals",
    "agent"
  ],
  "bin": {
    "lightscore": "src/cli.ts"
  },
  "exports": "./src/index.ts",
  "files": [
    "src",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
